# ==========================================
# PRUMA - Template de variaveis de ambiente
# ==========================================
# Copie este arquivo para .env e preencha com seus valores locais:
#   cp .env.example .env
#
# O arquivo .env JA ESTA NO .gitignore - nunca commite o .env real.
# ==========================================

# ==========================================
# Profile Spring Boot
# Opcoes: dev | prod
# ==========================================
SPRING_PROFILES_ACTIVE=dev

# ==========================================
# Banco de Dados
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pruma
DB_USERNAME=seu_usuario_aqui
DB_PASSWORD=sua_senha_aqui

# ==========================================
# JWT
# ==========================================
# OBRIGATORIO: minimo 32 caracteres (256 bits) para HS256.
# A aplicacao recusa iniciar se este valor estiver ausente ou fraco.
#
# Gere um secret de alta entropia (recomendado para PROD e DEV):
#   openssl rand -base64 64
#
# Exemplo de saida (NAO use este valor - gere o seu proprio):
#   K7gNU3sdo+OL0wNhqoVWhr3g6s1xYv72ol/pe/Unols3bQdR3oBqAKqAe/8KPRD4
#
# Para DEV pode usar qualquer string com 32+ caracteres, ex:
#   dev-secret-com-pelo-menos-32-caracteres-aqui
# ==========================================
JWT_SECRET=substitua-por-openssl-rand-base64-64
JWT_EXPIRATION=86400000
