# ==========================================
# PRUMA - Template de variaveis de ambiente
# ==========================================
# Copie este arquivo para .env e preencha com seus valores locais:
#   cp .env.example .env
#
# O arquivo .env JA ESTA NO .gitignore - nunca commite o .env real.
# ==========================================

# ==========================================
# Profile Spring Boot
# Opcoes: dev | prod
# ==========================================
SPRING_PROFILES_ACTIVE=dev

# ==========================================
# Banco de Dados
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pruma
DB_USERNAME=seu_usuario_aqui
DB_PASSWORD=sua_senha_aqui

# ==========================================
# JWT
# Para gerar um secret seguro em producao:
#   openssl rand -base64 64
# Em DEV pode usar qualquer string com 32+ caracteres.
# ==========================================
JWT_SECRET=substitua-por-um-secret-seguro-com-minimo-32-caracteres
JWT_EXPIRATION=86400000
